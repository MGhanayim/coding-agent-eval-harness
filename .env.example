# Copy to .env and fill in. Never commit .env (it is gitignored).

# --- Inference: Nebius Token Factory (Block A+) ---
NEBIUS_API_KEY=your-key-here

# --- MLflow tracking (Block F+) ---
# Local dev: http://127.0.0.1:5000 · under docker-compose: http://mlflow:5000
# (macOS: use 127.0.0.1, not localhost — AirPlay Receiver answers 403 on ::1 port 5000)
MLFLOW_TRACKING_URI=http://127.0.0.1:5000
MLFLOW_EXPERIMENT_NAME=swe-bench-evals

# --- Object storage: MinIO locally, Nebius Object Storage in prod (Block G+) ---
# Only the endpoint/credentials change between the two — same S3 API.
AWS_ENDPOINT_URL=http://localhost:9000
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
RUNS_BUCKET=runs

# --- Paths ---
# Root for run artifacts (a container path when running under Docker)
RUNS_ROOT=./runs
# Absolute HOST path to this repo — required by DockerOperator bind mounts (Block H+)
HOST_PROJECT_DIR=/absolute/path/to/coding-agent-eval-harness

# --- Execution mode (Block H+) ---
# subprocess (easy mode, default) or docker (DockerOperator; needs the image:
#   docker build -t coding-agent-eval-harness:latest .)
EXECUTION_MODE=subprocess
TASK_IMAGE=coding-agent-eval-harness:latest

# --- Airflow under docker-compose (Block I) ---
# Linux: set to your uid (id -u) so mounted files stay yours
AIRFLOW_UID=50000
# gid owning /var/run/docker.sock: Linux `getent group docker | cut -d: -f3`; macOS leave 0
DOCKER_GID=0
# macOS: AirPlay Receiver squats on host port 5000 — set e.g. 5002 to browse MLflow
MLFLOW_PORT=5000
